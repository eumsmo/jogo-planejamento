[sub_resource type="GDScript" id="GDScript_kvpfn"]
script/source = "extends HBoxContainer


func _ready() -> void:
	Game.instance.planning.on_profiles_changed.connect(on_subjects_change)


func on_subjects_change(quant: int) -> void:
	for child in get_children():
		child.queue_free()
	
	for i in range(0, quant):
		var button = create_button(i)
		button.pressed.connect(button_clicked.bind(i))
		add_child(button)


func create_button(idx: int) -> Button:
	var button = Button.new()
	button.text += \"Subject \" + str(idx+1)
	return button

func button_clicked(idx: int) -> void:
	Game.instance.planning.change_current_profile(idx)
"

