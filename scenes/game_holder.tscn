[sub_resource type="GDScript" id="GDScript_3txyw"]
script/source = "extends Control

func _ready() -> void:
	Game.instance.planning.delete_confirmation_requested.connect(requested)

func requested() -> void:
	show()

func on_yes() -> void:
	close()
	Game.instance.planning.answer_delete_request(true)

func on_no() -> void:
	close()
	Game.instance.planning.answer_delete_request(false)

func close() -> void:
	hide()
"

